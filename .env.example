LLM_HOST=<IP serwera GPU, np. 192.168.43.x>
LLM_USER=truenas_admin
# Generate: cat ~/.ssh/id_ed25519 | base64 -w 0
SSH_PRIVATE_KEY_B64=<base64 encoded private key — no newlines>

IPMI_HOST=<IP modułu BMC/IPMI serwera>
IPMI_USER=ADMIN
IPMI_PASS=<your-ipmi-password>
# IPMI_INTERFACE=lanplus   # lanplus (IPMI v2, default), lan (IPMI v1.5)

# Custom wake/sleep commands — override ipmitool defaults for non-Supermicro BMC
# Dell iDRAC:  WAKE_CMD=racadm -r $IPMI_HOST -u $IPMI_USER -p $IPMI_PASS serveraction powerup
# HP iLO:      WAKE_CMD=curl -sk -u $IPMI_USER:$IPMI_PASS -X POST https://$IPMI_HOST/rest/v1/Systems/1/Actions/ComputerSystem.Reset -d '{"ResetType":"On"}'
# IPMI v1.5:   WAKE_CMD=ipmitool -I lan -H $IPMI_HOST -U $IPMI_USER -P $IPMI_PASS chassis power on
# WAKE_CMD=
# SLEEP_CMD=

# Ollama REST API (default: http://<LLM_HOST>:11434)
# OLLAMA_BASE_URL=<http://LLM_HOST:11434>

# TrueNAS App name for Ollama (default: ollama)
# OLLAMA_APP_NAME=ollama

HOST_PORT=3788
PORT=3000
TZ=Europe/Warsaw
