LLM_HOST=<IP serwera GPU, np. 192.168.43.x>
LLM_USER=truenas_admin
# Generate: cat ~/.ssh/id_ed25519 | base64 -w 0
SSH_PRIVATE_KEY_B64=<base64 encoded private key — no newlines>

IPMI_HOST=<IP modułu BMC/IPMI serwera>
IPMI_USER=ADMIN
IPMI_PASS=<your-ipmi-password>

# Ollama REST API (default: http://<LLM_HOST>:11434)
# OLLAMA_BASE_URL=<http://LLM_HOST:11434>

# TrueNAS App name for Ollama (default: ollama)
# OLLAMA_APP_NAME=ollama

HOST_PORT=3788
PORT=3000
TZ=Europe/Warsaw
