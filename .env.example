LLM_HOST=<GPU server IP, e.g. 192.168.1.x>
LLM_USER=truenas_admin
# Generate: cat ~/.ssh/id_ed25519 | base64 -w 0
SSH_PRIVATE_KEY_B64=<base64 encoded private key — no newlines>

IPMI_HOST=<BMC/IPMI module IP>
IPMI_USER=ADMIN
IPMI_PASS=<your-ipmi-password>

# ── Power control ─────────────────────────────────────────────────────
# Uncomment the block matching your hardware.
# Only one WAKE_CMD / SLEEP_CMD pair should be active at a time.
#
# [A] Supermicro / most servers with IPMI v2.0 (DEFAULT — no changes needed)
#     Used automatically when WAKE_CMD/SLEEP_CMD are not set.
#
# [B] Servers with IPMI v1.5:
# WAKE_CMD=ipmitool -I lan -H $IPMI_HOST -U $IPMI_USER -P $IPMI_PASS chassis power on
# SLEEP_CMD=ipmitool -I lan -H $IPMI_HOST -U $IPMI_USER -P $IPMI_PASS chassis power soft
#
# [C] Dell iDRAC:
# WAKE_CMD=racadm -r $IPMI_HOST -u $IPMI_USER -p $IPMI_PASS serveraction powerup
# SLEEP_CMD=racadm -r $IPMI_HOST -u $IPMI_USER -p $IPMI_PASS serveraction graceshutdown
#
# [D] HP iLO (Redfish API):
# WAKE_CMD=curl -sk -u $IPMI_USER:$IPMI_PASS -X POST https://$IPMI_HOST/redfish/v1/Systems/1/Actions/ComputerSystem.Reset -d '{"ResetType":"On"}'
# SLEEP_CMD=curl -sk -u $IPMI_USER:$IPMI_PASS -X POST https://$IPMI_HOST/redfish/v1/Systems/1/Actions/ComputerSystem.Reset -d '{"ResetType":"GracefulShutdown"}'
# ─────────────────────────────────────────────────────────────────────

# TrueNAS web UI URL — kliknięcie IP w nagłówku (domyślnie https://LLM_HOST)
# TRUENAS_URL=http://192.168.1.x:2080

# Ollama REST API (default: http://<LLM_HOST>:11434)
# OLLAMA_BASE_URL=<http://LLM_HOST:11434>

# TrueNAS App name for Ollama (default: ollama)
# OLLAMA_APP_NAME=ollama

# Polling interval in seconds (default: 5)
# POLL_INTERVAL_SEC=5

# ── LAN PORTS widget ──────────────────────────────────────────────────
# Widget is HIDDEN by default. To enable it, set NETWORK_PHYS_IFACES.
#
# Step 1 — find your interface names:
#   ssh <user>@<LLM_HOST> "cat /proc/net/dev"
#   (look for physical ports like eno1, eno2, eth0, enp3s0, etc.)
#
# Step 2 — uncomment and fill in:
#
# NETWORK_PHYS_IFACES=eno1,eno2     # required — ports shown as individual bars
# NETWORK_HOST_IFACE=br0            # optional — shown as "host" summary line
#                                   # (use br0 on TrueNAS, bond0 otherwise, or leave empty)
#
# Link speed is auto-detected from /sys/class/net/<iface>/speed (Mbit/s).
# Override only if auto-detect is wrong (e.g. virtual NICs reporting -1):
# NETWORK_LINK_SPEED_MBIT=1000
# ─────────────────────────────────────────────────────────────────────

HOST_PORT=3788
PORT=3000
TZ=Europe/Warsaw
